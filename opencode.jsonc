{
  "$schema": "https://opencode.ai/config.json",

  // --- Model ---
  "default_agent": "Generalist",

  // --- Skills ---
  //"skills": {
  //  "paths": ["~/.config/opencode/opencode_v4/skills"]
  //},

  // --- LSP ---
  "lsp": true,

  // --- MCP ---
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-af45b65b-e437-4cbe-95f7-2f5b5ef002cb"
      },
      "enabled": true
    }
  },

  // --- Built-in agents ---
  "agent": {
    "build": { "disable": true },
    "plan": { "disable": true }
  },

  // --- Sharing ---
  "share": "disabled",

  // --- Updates ---
  "autoupdate": "notify",

  // --- Watcher ---
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".git/**",
      "**/*.lock",
      "**/__pycache__/**",
      "**/*.pyc"
    ]
  }
}
